{
  "expo": {
    "name": "LittleLoom",
    "slug": "LittleLoom",
    "scheme": "littleloom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#E6F4FE",
    "primaryColor": "#667eea",
    "owner": "ondieki",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0f0f1e"
      }
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/**/*",
      "node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/*.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tpm.littleloom",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "NSFaceIDUsageDescription": "This app uses Face ID to securely log you into your account.",
        "NSPhotoLibraryUsageDescription": "LittleLoom needs access to your photos to let you attach them to baby logs, milestones, and to automatically detect baby-related photos in your gallery.",
        "NSPhotoLibraryAddUsageDescription": "LittleLoom needs permission to save photos to your library.",
        "NSCameraUsageDescription": "LittleLoom needs camera access to let you capture photos for baby logs and milestones.",
        "NSMicrophoneUsageDescription": "LittleLoom may use the microphone when recording videos of your baby.",
        "NSLocationWhenInUseUsageDescription": "LittleLoom uses your location to tag where photos were taken.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "LittleLoom uses your location to tag where photos were taken, even in the background.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification",
          "processing"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIUserInterfaceStyle": "Automatic",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.tpm.littleloom",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withPackagingOptions.js",
      "./plugins/withStripeFix.js",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "kotlinVersion": "1.9.25"
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow LittleLoom by TPM Solutions to use Face ID."
        }
      ],
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#667eea"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LittleLoom to access your photos to attach them to baby logs and milestones.",
          "cameraPermission": "Allow LittleLoom to use your camera to capture photos for baby logs and milestones.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow LittleLoom to access your photos for automatic baby photo detection and gallery management.",
          "savePhotosPermission": "Allow LittleLoom to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow LittleLoom to use your location to tag where photos were taken."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "dark": {
            "image": "./assets/splash-icon.png",
            "backgroundColor": "#1a1a1a"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-localization",
      "expo-asset",
      "expo-audio",
      "expo-video",
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "e9e00b01-6623-4a60-b3e9-dbf5e2ca7aac"
      },
      "developer": {
        "name": "TPM Solutions",
        "website": "https://tpmsolutions.co.ke"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ]
  }
}